{
  "kind": "collectionType",
  "collectionName": "order_items",
  "info": {
    "singularName": "order-item",
    "pluralName": "order-items",
    "displayName": "Order Item",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "order": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::order.order",
      "inversedBy": "order_items"
    },
    "quantity": {
      "type": "integer"
    },
    "price": {
      "type": "decimal"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "cooking",
        "ready"
      ],
      "default": "pending"
    },
    "dish": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::dish.dish",
      "inversedBy": "order_items"
    }
  }
}
